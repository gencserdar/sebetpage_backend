# ============================================================================
# Copy to `.env` and fill every value. Compose AND every Spring app refuse
# to start if any required key is missing. NEVER commit `.env`.
#
# Passwords: prefer openssl rand -base64 24 (no `$` chars). A literal `$` in a
# value is only a problem when docker-compose.yml interpolates it via ${VAR}.
# ============================================================================

# ---------- Crypto / signing keys -------------------------------------------
# Generate each with: openssl rand -base64 32
JWT_SECRET=change-me
CHAT_AES_KEY_BASE64=change-me
REFRESH_TOKEN_HMAC_KEY=change-me

# ---------- JWT TTLs --------------------------------------------------------
JWT_EXPIRATION=300000
REFRESH_EXPIRATION_DEFAULT=172800
REFRESH_EXPIRATION_REMEMBER=2592000

# ---------- Database --------------------------------------------------------
DB_USERNAME=root
DB_PASSWORD=change-me
AUTH_DB_PORT=3307
USER_DB_PORT=3308
COMMUNITY_DB_PORT=3309
CHAT_DB_PORT=3310
DB_URL=jdbc:mysql://auth-db:3306/auth_db?createDatabaseIfNotExist=true&allowPublicKeyRetrieval=true&useSSL=false

# ---------- Service ports ---------------------------------------------------
AUTH_HTTP_PORT=8101
AUTH_GRPC_PORT=9101
USER_HTTP_PORT=8102
USER_GRPC_PORT=9102
COMMUNITY_HTTP_PORT=8103
COMMUNITY_GRPC_PORT=9103
CHAT_HTTP_PORT=8104
CHAT_GRPC_PORT=9104
GATEWAY_PORT=8000

# ---------- gRPC discovery (gateway → services) -----------------------------
AUTH_GRPC_HOST=auth-service
USER_GRPC_HOST=user-service
COMMUNITY_GRPC_HOST=community-service
CHAT_GRPC_HOST=chat-service
AUTH_SERVICE_GRPC=static://auth-service:9101
USER_SERVICE_GRPC=static://user-service:9102

# ---------- RabbitMQ --------------------------------------------------------
RABBITMQ_USER=change-me
RABBITMQ_PASS=change-me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---------- SMTP ------------------------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# ---------- Upload storage (profile / group photos) -------------------------
# Shared Docker volume mounted on user-service (write) and api-gateway (read).
UPLOAD_STORAGE_DIR=/data/uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:8000/uploads

# ---------- Redis -----------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me

# ---------- Cassandra (chat messages) ---------------------------------------
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=chat
CASSANDRA_DATACENTER=datacenter1
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=change-me

# ---------- OpenSearch (user + community search) ----------------------------
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=http
# Leave empty in local dev (security plugin disabled). For prod with HTTPS + auth:
# OPENSEARCH_SCHEME=https
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=Admin123!change-me
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# ---------- App envs --------------------------------------------------------
APP_ENV=dev
FRONTEND_BASE_URL=http://localhost:3000
GATEWAY_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_SIZE=5MB
TRUST_PROXY_HEADERS=false

GRPC_CLIENT_NEGOTIATION_TYPE=PLAINTEXT
GRPC_SERVER_SECURITY_ENABLED=false
GRPC_SERVER_SECURITY_CLIENT_AUTH=NONE

RATE_LIMIT_LOGIN_CAPACITY=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_REGISTER_CAPACITY=3
RATE_LIMIT_REGISTER_WINDOW_SECONDS=60
RATE_LIMIT_FORGOT_PASSWORD_CAPACITY=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_SECONDS=3600
RATE_LIMIT_REQUEST_EMAIL_CHANGE_CAPACITY=5
RATE_LIMIT_REQUEST_EMAIL_CHANGE_WINDOW_SECONDS=3600
RATE_LIMIT_REQUEST_PASSWORD_CHANGE_CAPACITY=5
RATE_LIMIT_REQUEST_PASSWORD_CHANGE_WINDOW_SECONDS=3600
RATE_LIMIT_ACTIVATE_CAPACITY=20
RATE_LIMIT_ACTIVATE_WINDOW_SECONDS=60
RATE_LIMIT_RESET_PASSWORD_CAPACITY=10
RATE_LIMIT_RESET_PASSWORD_WINDOW_SECONDS=60

INTERNAL_GRPC_TOKEN=change-me
WS_TICKET_TTL_SECONDS=30

ACTIVATION_CODE_TTL_MINUTES=1440
RESET_CODE_TTL_MINUTES=30
RESET_CODE_MAX_ATTEMPTS=5

ACCOUNT_CHANGE_CODE_TTL_MINUTES=10
ACCOUNT_CHANGE_CODE_MAX_ATTEMPTS=5

# ---------- Messaging groups (private chat groups in chat-service) ----------
RATE_LIMIT_MESSAGING_GROUP_WRITE_CAPACITY=30
RATE_LIMIT_MESSAGING_GROUP_WRITE_WINDOW_SECONDS=60
RATE_LIMIT_MESSAGING_GROUP_PHOTO_CAPACITY=10
RATE_LIMIT_MESSAGING_GROUP_PHOTO_WINDOW_SECONDS=300
MESSAGING_GROUP_MAX_MEMBERS=50
MESSAGING_GROUP_MAX_TITLE_CHARS=120
MESSAGING_GROUP_MAX_DESCRIPTION_CHARS=1000
RATE_LIMIT_CHAT_SEND_CAPACITY=120
RATE_LIMIT_CHAT_SEND_WINDOW_SECONDS=60
RATE_LIMIT_PROFILE_SETTINGS_WRITE_CAPACITY=30
RATE_LIMIT_PROFILE_SETTINGS_WRITE_WINDOW_SECONDS=60
RATE_LIMIT_PROFILE_PHOTO_CAPACITY=10
RATE_LIMIT_PROFILE_PHOTO_WINDOW_SECONDS=300
RATE_LIMIT_SEARCH_CAPACITY=60
RATE_LIMIT_SEARCH_WINDOW_SECONDS=60
RATE_LIMIT_FRIEND_WRITE_CAPACITY=30
RATE_LIMIT_FRIEND_WRITE_WINDOW_SECONDS=60
RATE_LIMIT_BLOCK_WRITE_CAPACITY=20
RATE_LIMIT_BLOCK_WRITE_WINDOW_SECONDS=60
CHAT_MESSAGE_MAX_CHARS=2000
CHAT_EVENTS_RABBIT_ENABLED=true
